# Variáveis de ambiente — NÃO commitar este arquivo
# Copie para .env.local e preencha com seus dados do Supabase

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_AQUI

# URL do Apps Script (mantido para espelhamento no Sheets)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_SCRIPT/exec

# Senha admin padrão (será hash SHA-256 no frontend)
# IMPORTANTE: troque após o primeiro acesso
VITE_ADMIN_DEFAULT_PWD=admin2026
